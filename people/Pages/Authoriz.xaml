<Page x:Class="people.Pages.Authoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:people.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authoriz">

    <Grid Background="#FF1F3447" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Авторизация"
                   HorizontalAlignment="Center"
                   Margin="0,28,0,20"
                   FontFamily="Cambria Math"
                   Foreground="#FFE6F4FF"
                   FontSize="36"/>

        <Grid Grid.Row="1" HorizontalAlignment="Center" Width="274">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Введите логин"
                       Width="274"
                       TextAlignment="Left"
                       FontFamily="Cambria Math"
                       FontSize="20"
                       Foreground="#FFE6F4FF"
                       HorizontalAlignment="Left"/>

            <TextBox x:Name="LoginBox"
                     Grid.Row="1"
                     Width="274"
                     Height="31"
                     HorizontalAlignment="Stretch"
                     FontFamily="Cambria Math"
                     AutomationProperties.Name="LoginBox"
                     TabIndex="50"/>

            <TextBlock Grid.Row="3"
                       Text="Введите пароль"
                       Width="274"
                       TextAlignment="Left"
                       FontFamily="Cambria Math"
                       FontSize="20"
                       Foreground="#FFE6F4FF"
                       HorizontalAlignment="Left"/>

            <PasswordBox x:Name="PassBox"
                         Grid.Row="4"
                         Width="274"
                         Height="31"
                         HorizontalAlignment="Stretch"
                         FontFamily="Cambria Math"
                         AutomationProperties.Name="PassBox"
                         TabIndex="50"/>

            <Button x:Name="LoginButton"
                    Grid.Row="6"
                    Content="Войти"
                    Width="274"
                    Height="37"
                    FontFamily="Cambria Math"
                    FontSize="16"
                    Click="LoginButton_Click"
                    Background="Black"
                    Foreground="White"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}" Margin="4,4,-4,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="OpenRegButton"
                    Grid.Row="8"
                    Content="Зарегистрироватся"
                    Width="274"
                    Height="37"
                    FontFamily="Cambria Math"
                    FontSize="16"
                    Click="OpenRegButton_Click"
                    Background="Black"
                    Foreground="White"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}" Margin="4,4,-4,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Page>

