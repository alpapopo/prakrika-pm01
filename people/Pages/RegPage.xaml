<Page x:Class="people.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:people.Pages"
      mc:Ignorable="d" d:DesignWidth="800" MinHeight="550"
      Title="RegPage">

    <Grid Background="#FF1F3447">
        <Label Content="Регистрация" HorizontalAlignment="Center" Margin="0,1,0,0" VerticalAlignment="Top" FontFamily="Cambria Math" Foreground="#FFE6F4FF" FontSize="36"/>
        <Label Content="Введите логин" HorizontalAlignment="Center" Margin="-110,62,0,0" VerticalAlignment="Top" FontFamily="Cambria Math" Foreground="#FFE6F4FF" FontSize="20"/>
        <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,98,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="LoginBox" TabIndex="50" FontFamily="Cambria Math"/>
        <Label Content="Введите пароль" HorizontalAlignment="Center" Margin="-90,139,0,0" VerticalAlignment="Top" FontFamily="Cambria Math" Foreground="#FFE6F4FF" FontSize="20"/>
        <PasswordBox x:Name="PassBox" HorizontalAlignment="Center" Margin="0,172,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="PassBox" PasswordChanged="PassBox_PasswordChanged" TabIndex="50" FontFamily="Cambria Math"/>
        <Label Content="Подтвердите пароль" HorizontalAlignment="Center" Margin="-40,210,0,0" VerticalAlignment="Top" FontFamily="Cambria Math" Foreground="#FFE6F4FF" FontSize="20"/>
        <PasswordBox x:Name="PassBoxV" HorizontalAlignment="Center" Margin="0,243,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="PassBoxV" PasswordChanged="PassBoxV_PasswordChanged" TabIndex="50" FontFamily="Cambria Math"/>
        <Label Content="Введите почту" HorizontalAlignment="Center" Margin="-110,279,0,0" VerticalAlignment="Top" FontFamily="Cambria Math" Foreground="#FFE6F4FF" FontSize="20"/>
        <TextBox x:Name="EmailBox" HorizontalAlignment="Center" Margin="0,315,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="EmailBox" TabIndex="100" FontFamily="Cambria Math"/>
        <Button x:Name="AddButton" Content="Зарегистрироватся" HorizontalAlignment="Center" Margin="0,438,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Cambria Math" FontSize="16" Background="#FF6FCF97" Foreground="Black" Click="AddButton_Click"/>
        <Button x:Name="GoToAutogizButton" Content="Назад к авторизации" HorizontalAlignment="Center" Margin="0,480,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Cambria Math" FontSize="16" Background="#FF6FCF97" Foreground="Black" Click="GoToAutogizButton_Click"/>
        <Label Content="Выберите город" HorizontalAlignment="Center" Margin="-85,357,0,0" VerticalAlignment="Top" FontFamily="Cambria Math" Foreground="#FFE6F4FF" FontSize="20"/>
        <ComboBox x:Name="CityBox" HorizontalAlignment="Center" Margin="0,390,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="CityBox" TabIndex="100" FontFamily="Cambria Math"></ComboBox>
    </Grid>
</Page>



