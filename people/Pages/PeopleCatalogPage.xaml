<Page x:Class="people.Pages.PeopleCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450"
      MinHeight="500"
      Title="PeopleCatalogPage">

    <Grid Background="#FF1F3447" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="ComboFilter"
                      Grid.Column="0"
                      Height="30"
                      VerticalAlignment="Center"
                      SelectionChanged="ComboFilter_SelectionChanged"/>

            <ComboBox x:Name="ComboSort"
                      Grid.Column="2"
                      Height="30"
                      VerticalAlignment="Center"
                      SelectionChanged="ComboSort_SelectionChanged"/>

            <TextBox x:Name="TextSearch"
                     Grid.Column="4"
                     Height="30"
                     VerticalAlignment="Center"
                     TextChanged="TextSearch_TextChanged"
                     TabIndex="100"
                     ToolTip="Поиск..."/>

            <Button x:Name="AddProductsButton"
                    Grid.Column="6"
                    Content="Панель администратора"
                    Height="30"
                    Click="AddProductsButton_Click"
                    Loaded="AddProductsButton_Loaded"/>

            <Button x:Name="GoToBasketButton"
                    Grid.Column="8"
                    Height="30"
                    Width="50"
                    Click="GoToBasketButton_Click_1">
                <Button.Background>
                    <ImageBrush ImageSource="/Pages/free-icon-shopping-cart-5087816.png" Stretch="Uniform"/>
                </Button.Background>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White">
            <ListView x:Name="ListProducts"
                      BorderThickness="0"
                      Background="White"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#FFD8D8D8" Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="180" Height="180" ClipToBounds="True" Background="#FFF2F2F2">
                                    <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Product}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Margin="0,0,0,8" FontSize="15">
                                        <Run Text="Специализация: "/>
                                        <Run Text="{Binding Categories.NameCategory}"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" FontSize="15">
                                        <Run Text="Описание: "/>
                                        <Run Text="{Binding Descripton}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="15">
                                        <Run Text="Цена: "/>
                                        <Run Text="{Binding Price}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                    <Button x:Name="AddToBusketButton"
                                            Content="Добавить в подборку"
                                            Width="150"
                                            Height="32"
                                            Click="AddToBusketButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
