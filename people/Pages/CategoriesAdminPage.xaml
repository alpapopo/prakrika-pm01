<Page x:Class="people.Pages.CategoriesAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="920"
      Title="CategoriesAdminPage" Width="920">
    <Grid Background="#FF1F3447">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="CategoriesGrid"
                  Margin="0,0,0,10"
                  AutoGenerateColumns="False"
                  SelectionChanged="CategoriesGrid_SelectionChanged"
                  IsReadOnly="True"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdCategory}" Width="80"/>
                <DataGridTextColumn Header="Название специализации" Binding="{Binding NameCategory}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0"
                   Grid.Column="0"
                   Content="Название специализации"
                   Foreground="White"
                   Margin="0,0,0,4"/>

            <TextBox x:Name="CategoryNameBox"
                     Grid.Row="1"
                     Grid.Column="0"
                     Width="300"
                     Height="30"
                     TabIndex="50"
                     ToolTip="Название специализации"/>

            <Button Grid.Row="1"
                    Grid.Column="2"
                    Content="Добавить"
                    Height="30"
                    Click="AddButton_Click" Margin="4,4,5,4" Grid.ColumnSpan="2"/>
            <Button Grid.Row="1"
                    Grid.Column="4"
                    Content="Сохранить"
                    Height="30"
                    Click="EditButton_Click" Grid.ColumnSpan="2" Margin="4,4,1,4"/>
            <Button Grid.Row="1"
                    Grid.Column="6"
                    Content="Удалить"
                    Height="30"
                    Click="DeleteButton_Click" Margin="4,4,0,4"/>
        </Grid>
    </Grid>
</Page>
