<Page x:Class="people.Pages.OrdersAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" d:DesignHeight="400"
      Title="OrdersAdminPage" Width="920">
    <Grid Background="#FF1F3447">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False" SelectionChanged="OrdersGrid_SelectionChanged" FontFamily="Cambria Math" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding IdOrder}" Width="60"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding IdUser}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Data}" Width="150"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusOrders.NameStatusOrder}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="ID клиента" Foreground="White" Margin="0,0,0,4"/>
            <Label Grid.Row="0" Grid.Column="2" Content="Дата" Foreground="White" Margin="0,0,0,4"/>
            <Label Grid.Row="0" Grid.Column="4" Content="Сумма" Foreground="White" Margin="0,0,0,4"/>
            <Label Grid.Row="0" Grid.Column="6" Content="Статус" Foreground="White" Margin="0,0,0,4"/>

            <TextBox x:Name="UserIdBox" Grid.Row="1" Grid.Column="0" Width="90" Height="30" FontFamily="Cambria Math" ToolTip="ID клиента" TabIndex="50"/>
            <DatePicker x:Name="OrderDateBox" Grid.Row="1" Grid.Column="2" Width="140" Height="30" FontFamily="Cambria Math" DisplayDateStart="2026/03/30"/>
            <TextBox x:Name="OrderPriceBox" Grid.Row="1" Grid.Column="4" Width="120" Height="30" FontFamily="Cambria Math" ToolTip="Сумма" TabIndex="50"/>
            <ComboBox x:Name="StatusBox" Grid.Row="1" Grid.Column="6" Width="180" Height="30" DisplayMemberPath="NameStatusOrder" SelectedValuePath="IdStatusOrder" FontFamily="Cambria Math"/>
            <Button Grid.Row="1" Grid.Column="8" Content="Добавить" Height="30" Click="AddButton_Click" FontFamily="Cambria Math" Foreground="Black" Background="#FF6FCF97" Grid.ColumnSpan="2" Margin="4,4,0,4"/>
            <Button Grid.Row="1" Grid.Column="10" Content="Сохранить" Height="30" Click="EditButton_Click" FontFamily="Cambria Math" Foreground="Black" Background="#FF6FCF97" Grid.ColumnSpan="2" Margin="4,4,0,4"/>
            <Button Grid.Row="1" Grid.Column="12" Content="Удалить" Height="30" Click="DeleteButton_Click" FontFamily="Cambria Math" Foreground="Black" Background="#FF6FCF97" Margin="4,4,-8,4"/>
        </Grid>
    </Grid>
</Page>



