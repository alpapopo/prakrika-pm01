<Application x:Class="people.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:people"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#FF1F3447"/>
        <SolidColorBrush x:Key="AppAccentBrush" Color="#FF6FCF97"/>
        <SolidColorBrush x:Key="AppTextLightBrush" Color="#FFE6F4FF"/>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Cambria Math"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontFamily" Value="Cambria Math"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Cambria Math"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontFamily" Value="Cambria Math"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cambria Math"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Cambria Math"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Cambria Math"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>
    </Application.Resources>
</Application>
